# AgriVision AI Environment Configuration Template
# Copy this file to .env.local in apps/web/ and apps/admin/, and customize the values.

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-safe-for-browser

# Server-only keys (Keep these safe, do not prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-bypasses-rls

# AI Models (Gemini SDK)
GEMINI_API_KEY=your-gemini-api-key

# Third-party APIs
NEXT_PUBLIC_WEATHER_API_KEY=your-tomorrow-io-or-open-weather-api-key
NEXT_PUBLIC_SENTINEL_HUB_ID=your-sentinel-hub-instance-id
SENTINEL_HUB_SECRETE=your-sentinel-hub-client-secret

# Internal API routes
NEXT_PUBLIC_ADVISORY_API_URL=http://localhost:8000/advisory
INTERNAL_SHARED_SECRET=super-secret-internal-key-2026
